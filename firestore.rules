rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "saurabhmotalkar2021@gmail.com" && request.auth.token.email_verified == true;
    }

    function isProjectOwner(projectId) {
        return isAuthenticated() && (get(/databases/$(database)/documents/projects/$(projectId)).data.uid == request.auth.uid);
    }

    // ===============================================================
    // Collections
    // ===============================================================
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && uidUnchanged() && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && uidNotModified() && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read, write: if isDocOwner() || isAdmin();
    }

    match /projects/{projectId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();

      // Project-nested items
      match /socialPosts/{postId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /activities/{activityId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /generatedContent/{contentId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /summaries/{summaryId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /magicResults/{resultId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /analytics/{docId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /performanceAlerts/{alertId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /performanceLogs/{logId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /automationRules/{ruleId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /workflows/{workflowId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /workflowExecutions/{executionId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /dynamicVariables/{variableId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /aiChatMessages/{messageId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
      match /seoStrategies/{strategyId} { allow read, write: if isProjectOwner(projectId) || isAdmin(); }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
